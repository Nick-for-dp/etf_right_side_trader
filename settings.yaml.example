    #   weight: 0.0
  regime:
    enabled: true
    lookback_days: 180
    min_indices: 4
    hot_score: 0.55
    cold_score: -0.55
    hot_ratio: 0.6
    cold_ratio: 0.6

data:
  # LongTermOdds 需要约 3 年交易窗口，1500 日历天提供足够 rolling 冗余。
  lookback_days: 1500

scheduler:
  run_time: "07:00"
  timezone: "Asia/Shanghai"
