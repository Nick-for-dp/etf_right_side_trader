# ETF 右侧交易助手配置模板
# 复制为 settings.yaml 后按需调整。本文件不包含密钥，数据库密码写入 .env。

etf_list:
  - symbol: "588000"
    name: "科创50ETF"
    category: "broad"
  - symbol: "513180"
    name: "恒生科技ETF华夏"
    category: "broad"
  - symbol: "513100"
    name: "纳指ETF国泰"
    category: "broad"
  - symbol: "159949"
    name: "创业板50ETF华安"
    category: "broad"
  - symbol: "512480"
    name: "半导体ETF国联安"
    category: "sector"
  - symbol: "515700"
    name: "新能源车ETF平安"
    category: "sector"
  - symbol: "512660"
    name: "军工ETF国泰"
    category: "sector"

database:
  driver: "postgresql"

strategy:
  type: "multi_indicator_scoring"
  params:
    ma_short: 20
    ma_long: 60
    weights:
      trend: 0.35
      macd: 0.25
      rsi: 0.15
      bb: 0.25
    thresholds:
      buy: 50
      sell: -50
    cooldown_days: 5

risk_control:
  rules:
    - type: "stop_loss"
      params:
        threshold: -0.08
    - type: "trailing_stop"
      params:
        profit_threshold: 0.10
        drawdown_threshold: 0.03

market:
  indices:
    - code: "000001"
      name: "上证指数"
      baostock_code: "sh.000001"
      akshare_symbol: "sh000001"
      source: "baostock"
      weight: 1.5
    - code: "000300"
      name: "沪深300"
      baostock_code: "sh.000300"
      akshare_symbol: "sh000300"
      source: "baostock"
      weight: 1.5
    - code: "000905"
      name: "中证500"
      baostock_code: "sh.000905"
      akshare_symbol: "sh000905"
      source: "baostock"
      weight: 1.0
    - code: "000852"
      name: "中证1000"
      baostock_code: "sh.000852"
      akshare_symbol: "sh000852"
      source: "baostock"
      weight: 1.0
    - code: "399006"
      name: "创业板指"
      baostock_code: "sz.399006"
      akshare_symbol: "sz399006"
      source: "baostock"
      weight: 1.0
    - code: "000688"
      name: "科创50"
      baostock_code: "sh.000688"
      akshare_symbol: "sh000688"
      source: "akshare"
      weight: 1.0

    # ── 美股指数 ──
    - code: "NDX"
      name: "纳指100"
      akshare_symbol: ".NDX"
      source: "akshare_us"
      weight: 0.0   # 仅用于分市场门控，不参与 A 股热度评分

    # ── 港股指数 ──
    # - code: "HZ5017"
    #   name: "恒生科技指数"
    #   akshare_symbol: "HSTECH"    # 新浪港股接口代码
    #   tushare_code: "HZ5017.HI"   # Tushare 港股 ts_code
    #   source: "akshare_hk"
    #   weight: 0.0

    # ── 中证行业指数（行业门控 + 组合风控行业暴露用）──
