database:
  driver: "postgresql"

strategy:
  type: "multi_indicator_scoring"
  params:
    ma_short: 20
    ma_long: 60
    weights:
      trend: 0.35
      macd: 0.25
      rsi: 0.15
      bb: 0.25
    thresholds:
      buy: 50
      sell: -50
    cooldown_days: 5
    entry_add_budget:
      entry_ratio: 0.70
      add_steps:
        - ratio: 0.15
          require_profit: true
          min_score: 60
        - ratio: 0.15
          require_profit: true
          min_score: 70

risk_control:
  rules:
    - type: "max_holding_days"
      params:
        days: 90
    - type: "profile_stop_loss"
      params:
        default_profile: "fixed_8"

market:
  indices:
    - code: "000001"
      name: "上证指数"
      baostock_code: "sh.000001"
      akshare_symbol: "sh000001"
      source: "baostock"
      weight: 1.5
    - code: "000300"
      name: "沪深300"
      baostock_code: "sh.000300"
      akshare_symbol: "sh000300"
      source: "baostock"
      weight: 1.5
    - code: "000905"
      name: "中证500"
      baostock_code: "sh.000905"
      akshare_symbol: "sh000905"
      source: "baostock"
      weight: 1.0
    - code: "000852"
      name: "中证1000"
      baostock_code: "sh.000852"
      akshare_symbol: "sh000852"
      source: "baostock"
      weight: 1.0
    - code: "399006"
      name: "创业板指"
      baostock_code: "sz.399006"
      akshare_symbol: "sz399006"
      source: "baostock"
      weight: 1.0
    - code: "000688"
      name: "科创50"
      baostock_code: "sh.000688"
      akshare_symbol: "sh000688"
      source: "akshare"
      weight: 1.0

    # ── 美股指数 ──
    - code: "NDX"
      name: "纳指100"
      akshare_symbol: ".NDX"
      source: "akshare_us"
      weight: 0.0   # 仅用于分市场门控，不参与 A 股热度评分

    # ── 港股指数 ──
    - code: "HZ5017"
      name: "恒生科技指数"
      akshare_symbol: "HSTECH"
      tushare_code: "HKTECH"
      source: "tushare_global"
      weight: 0.0   # 仅用于分市场门控，不参与 A 股热度评分

    # ── 中证行业指数（行业门控 + 组合风控行业暴露用）──
    - code: "399967"
      name: "中证军工"
      akshare_symbol: "sz399967"
      tushare_code: "399967.SZ"
      source: "akshare"
      weight: 0.0
    # 以下指数在 Tushare 和 AKShare（新浪源）上均无数据，保留代码待后续寻找其他数据源。
